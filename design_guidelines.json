{
  "theme": "light",
  "archetype": "Organic & Earthy",
  "typography": {
    "headings": {
      "fontFamily": "Playfair Display, serif",
      "weights": ["400", "600", "700"],
      "styles": "Elegant, organic, serif"
    },
    "body": {
      "fontFamily": "DM Sans, sans-serif",
      "weights": ["400", "500", "600"],
      "styles": "Clean, legible, modern"
    },
    "rules": {
      "h1": "text-5xl sm:text-6xl+ tracking-tight leading-none",
      "h2": "text-4xl sm:text-5xl tracking-tight leading-tight",
      "h3": "text-2xl sm:text-3xl",
      "body": "text-base sm:text-lg leading-relaxed",
      "label": "uppercase text-xs tracking-[0.2em]"
    }
  },
  "colors": {
    "primary": {
      "DEFAULT": "#1a3a2a",
      "foreground": "#f0ece3"
    },
    "accent": {
      "DEFAULT": "#c8922a",
      "foreground": "#2b2b2b"
    },
    "background": {
      "light": "#f5f0e8",
      "dark": "#0d1f14",
      "DEFAULT": "#f5f0e8"
    },
    "text": {
      "light_bg": "#2b2b2b",
      "dark_bg": "#f0ece3",
      "DEFAULT": "#2b2b2b"
    },
    "border": {
      "DEFAULT": "rgba(26, 58, 42, 0.1)",
      "dark": "rgba(240, 236, 227, 0.1)"
    }
  },
  "layout_spacing": {
    "generous_spacing": "py-20 sm:py-32",
    "bento_grid": "grid grid-cols-1 md:grid-cols-12 gap-6",
    "card_padding": "p-8",
    "container": "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"
  },
  "visual_style": {
    "border_radius": "rounded-2xl",
    "shadows": "shadow-[0_8px_32px_rgba(26,58,42,0.08)]",
    "glassmorphism": "backdrop-blur-xl bg-[#f5f0e8]/70 border border-[#1a3a2a]/10",
    "dark_glass": "backdrop-blur-xl bg-[#0d1f14]/80 border border-white/10",
    "mist_effect": "CSS keyframe animations with layered translucent backgrounds for a slow-moving fog effect over the hero section."
  },
  "components_instructions": {
    "navbar": "Sticky, top-0, z-50. Use glassmorphism. Transparent at the very top, transitions to frosted glass on scroll.",
    "hero": "Full screen (min-h-screen). Absolute positioned mist layers (using Framer Motion or CSS). Dark overlay (bg-black/30) on hero image to ensure text contrast. All text in hero should be light (Cream). Main CTA to WhatsApp.",
    "cards": "Subtle rounded corners (rounded-2xl), soft shadow, off-white parchment background. Image hover zoom (overflow-hidden, hover:scale-105).",
    "buttons": "Primary buttons: #1a3a2a bg with #f0ece3 text. Accent buttons: #c8922a bg with #2b2b2b text. Include hover transitions.",
    "whatsapp_fab": "Fixed bottom-right position (z-50), standard WhatsApp green or Accent gold with a soft pulse or bounce animation.",
    "gallery": "Bento grid structure combining col-span-4, col-span-8, and row-span-2 variants to create a dynamic layout.",
    "tabs": "For Destinations section. Use Shadcn Tabs if applicable or custom pill-shaped toggles to switch between 'Available' and 'Coming Soon'."
  },
